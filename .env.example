# MISTRAL_API_KEY: Required for Mistral AI API calls.
# Get your free API key from https://console.mistral.ai/
# Configure this in your environment variables or .env file.
MISTRAL_API_KEY="YOUR_MISTRAL_API_KEY"

# NODE_ENV: Environment setting (development/production/test)
# Set to "production" for Vercel deployment
NODE_ENV="development"

# APP_URL: The URL where your app is hosted.
# For Vercel: https://your-app-name.vercel.app
APP_URL="MY_APP_URL"
